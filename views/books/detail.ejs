<h2><%= book.title %></h2>
<img height="150" width="100" src="<%= book.coverImagePath %>" />
<div>
  <p>Author:</p>
  <p><%= book.author.name %></p>
</div>
<div>
  <p>Publish Date:</p>
  <p><%= book.publishDate.toDateString() %></p>
</div>
<div>
  <p>Description:</p>
  <p><%= book.description %></p>
</div>
<div>
  <a href="/books/<%= book.id  %>/edit">Edit</a>
  <%- include('../partials/deleteForm.ejs', {url: `/books/${book.id}`}) %>
  <a href="/authors/<%= book.author.id %>">View Author</a>
</div>