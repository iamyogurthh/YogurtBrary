<div>
    <label>Title</label>
    <input type="text" name="title" value="<%= book.title %>" />
</div>

<div>
    <label>Title</label>
    <select name="author">
        <% authors.forEach(author => { %>
            <option  value="<%= author.id %>" <%= author.id === book.author ? "selected" : ""%>><%= author.name %></option>
        <% }) %>
    </select>
</div>

<div>
    <label>Category</label>
    <select name="category">
        <% categories.forEach(category => { %>
            <option  value="<%= category.id %>" <%= category.id === book.category ? "selected" : ""%>><%= category.name %></option>
        <% }) %>
    </select>
</div>

<div>
    <label>Publish Date</label>
    <input type="date" name="publishDate" value="<%= book.publishDate == null ? "" : book.publishDate.toISOString().split('T')[0] %>" />
</div>

<div>
    <label>Page Count</label>
    <input type="number" name="pageCount" value="<%= book.pageCount %>" min="1" />
</div>

<div>
    <label>Cover</label>
    <input type="file" name="cover" class="filepond"/>
</div>

<div>
    <label>Description</label>
    <textarea name="description"><%= book.description %></textarea>
</div>

